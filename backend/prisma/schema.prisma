// Configuration de la connexion
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- NOS ENUMS ---
enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  TEXT
  VOICE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// --- NOS TABLES ---
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  avatarUrl    String?
  bio          String?  @db.VarChar(190)
  customStatus String?  @db.VarChar(128)
  statusEmoji  String?  @db.VarChar(8)
  bannerUrl    String?
  servers      Member[]
  ownedServers Server[] // Les serveurs dont l'user est Owner
  channelReads UserChannelRead[] // Lecture par channel
  voiceConnection VoiceConnection? // Connexion vocale active (max 1)
  messageDeletions MessageDeletion[] // Messages supprimés par cet utilisateur
  friendshipsOne Friendship[] @relation("FriendshipUserOne")
  friendshipsTwo Friendship[] @relation("FriendshipUserTwo")
  friendshipsRequested Friendship[] @relation("FriendshipRequester")
  directConversationsOne DirectConversation[] @relation("DirectConversationUserOne")
  directConversationsTwo DirectConversation[] @relation("DirectConversationUserTwo")
  directMessages DirectMessage[] @relation("DirectMessageSender")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Server {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.VarChar(500)
  imageUrl    String?
  inviteCode  String   @unique

  // Règle : Un seul Owner par serveur
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  members     Member[]
  channels    Channel[]
  createdAt   DateTime @default(now())
}

model Member {
  id        String   @id @default(uuid())
  role      Role     @default(MEMBER)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  
  messages  Message[]
  createdAt DateTime @default(now())
  
  @@unique([userId, serverId]) // Un utilisateur ne peut être qu'une fois dans un serveur
}

model Channel {
  id          String      @id @default(uuid())
  name        String
  topic       String?  @db.VarChar(1024) // Topic/description du channel
  type        ChannelType @default(TEXT)
  position    Int         @default(0) // Position dans la liste (pour tri)

  serverId  String
  server    Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)

  messages  Message[]
  readReceipts UserChannelRead[] // Lecture par user
  voiceConnections VoiceConnection[] // Utilisateurs connectés au voice channel
  createdAt DateTime    @default(now())
}

model Message {
  id        String   @id @default(uuid())
  content   String   @db.Text

  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  attachments Attachment[]
  deletions  MessageDeletion[]
  
  // Statuts globaux (Niveau 3)
  deliveredAt DateTime? 
  // readAt est géré par user via UserChannelRead
  
  deletedAt DateTime? // Pour le Soft Delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model MessageDeletion {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId, messageId])
}

// --- MESSAGERIE AVANCÉE (Niveau 3) ---
// Stratégie "Read Receipts" optimisée par Channel
model UserChannelRead {
  id                String   @id @default(uuid())
  
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channelId         String
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  lastReadMessageId String?
  lastReadAt        DateTime @default(now())

  @@unique([userId, channelId]) // Une entrée par user par channel
  @@index([channelId, userId])
}

model Attachment {
  id        String   @id @default(uuid())
  url       String
  name      String
  size      Int
  mimeType  String

  messageId String?
  message   Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  uploadedBy String // userId of the uploader
  createdAt  DateTime @default(now())
}

// --- MODERATION : Bans ---
model Ban {
  id        String    @id @default(uuid())

  userId    String    // L'utilisateur banni
  serverId  String    // Le serveur depuis lequel il est banni

  bannedBy  String    // userId de l'admin/owner qui a banni
  reason    String?   // Raison optionnelle du ban

  expiresAt DateTime? // null = ban definitif, date = ban temporaire
  createdAt DateTime  @default(now())

  @@unique([userId, serverId]) // Un seul ban actif par user/server
}

// --- VOICE : Connexions vocales ---
model VoiceConnection {
  id          String   @id @default(uuid())

  userId      String   @unique // Un utilisateur ne peut être connecté qu'à un seul voice channel à la fois
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  isMuted     Boolean  @default(false) // Micro coupé
  isDeafened  Boolean  @default(false) // Son coupé (implique aussi muted)

  connectedAt DateTime @default(now())

  @@index([channelId]) // Index pour récupérer rapidement tous les utilisateurs d'un channel
}

// --- FRIENDS / DM ---
model Friendship {
  id          String           @id @default(uuid())
  userOneId   String
  userTwoId   String
  requesterId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  userOne     User @relation("FriendshipUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo     User @relation("FriendshipUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  requester   User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
  @@index([userOneId])
  @@index([userTwoId])
}

model DirectConversation {
  id        String   @id @default(uuid())
  userOneId String
  userTwoId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userOne   User @relation("DirectConversationUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo   User @relation("DirectConversationUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  messages  DirectMessage[]

  @@unique([userOneId, userTwoId])
  @@index([userOneId])
  @@index([userTwoId])
}

model DirectMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
