# ===========================================
# Backend - Variables d'environnement requises
# ===========================================
# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL (OBLIGATOIRE)
DATABASE_URL="postgresql://admin:mysecretpassword@localhost:5432/entangle?schema=public"

# Secret JWT (OBLIGATOIRE — le serveur refuse de démarrer sans)
JWT_SECRET="change-me-to-a-long-random-string"

# Port du serveur (optionnel, défaut: 3001)
PORT=3001

# URL du frontend pour CORS (optionnel, défaut: http://localhost:3000)
FRONTEND_URL="http://localhost:3000"
